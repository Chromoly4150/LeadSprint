# Public base URL for the API used by the web app
NEXT_PUBLIC_API_BASE=http://127.0.0.1:4000

# Public base URL for the web app itself (used for explicit auth redirects)
NEXT_PUBLIC_APP_URL=http://127.0.0.1:3000

# Clerk auth scaffold
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Shared secret for signed server-to-server auth requests from web -> api
INTERNAL_API_AUTH_SECRET=
